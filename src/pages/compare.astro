---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
const categoryLabels: Record<string, string> = {
  writing: 'Writing & Content', image: 'Image Generation', video: 'Video Creation',
  audio: 'Audio & Voice', coding: 'Coding & Development', productivity: 'Productivity',
  data: 'Data & Analytics', design: 'Design & Creative', marketing: 'Marketing & SEO', business: 'Business & Finance',
};
---

<BaseLayout title="Compare AI Tools Side-by-Side — AI Zest">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <!-- Header -->
    <div class="mb-8">
      <a href="/" class="text-sm text-gray-500 dark:text-gray-400 hover:text-[#3B82F6] transition-colors">← Back to Home</a>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mt-2 flex items-center gap-3">
        <svg class="w-6 h-6 sm:w-8 sm:h-8 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        Compare AI Tools
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-1">
        Select up to 3 tools to compare features, pricing, ratings, and more.
      </p>
    </div>

    <!-- Tool selector -->
    <div class="mb-10 p-6 rounded-xl bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[0, 1, 2].map(i => (
          <div key={i}>
            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">
              Tool {i + 1}
            </label>
            <select id={`tool-select-${i}`} class="tool-select w-full px-3 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 
              bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 text-sm
              focus:outline-none focus:ring-2 focus:ring-[#3B82F6] focus:border-transparent">
              <option value="">— Select a tool —</option>
              {tools.sort((a, b) => a.data.name.localeCompare(b.data.name)).map(t => (
                <option value={t.data.slug} data-category={t.data.category}>
                  {t.data.name} ({categoryLabels[t.data.category] || t.data.category})
                </option>
              ))}
            </select>
          </div>
        ))}
      </div>
      <div class="mt-4 text-center">
        <button id="compare-btn" disabled class="px-6 py-2.5 rounded-lg bg-[#3B82F6] text-white text-sm font-medium 
          hover:bg-[#2563EB] transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
          Compare Now
        </button>
      </div>
    </div>

    <!-- Comparison results -->
    <div id="compare-results" class="hidden"></div>
  </div>
</BaseLayout>

<script>
(function() {
  // Load all tool data
  let allTools = [];
  fetch('/api/tools.json')
    .then(r => r.json())
    .then(data => { allTools = data; })
    .catch(() => {});

  const selects = document.querySelectorAll('.tool-select');
  const btn = document.getElementById('compare-btn');
  const results = document.getElementById('compare-results');

  // Enable/disable compare button
  function updateBtn() {
    const selected = [...selects].map(s => s.value).filter(v => v);
    btn.disabled = selected.length < 2;
  }
  selects.forEach(s => s.addEventListener('change', updateBtn));
  updateBtn();

  btn.addEventListener('click', async () => {
    const slugs = [...selects].map(s => s.value).filter(v => v);
    if (slugs.length < 2) return;

    btn.textContent = 'Loading...';
    btn.disabled = true;

    try {
      // Fetch each tool's full data
      const toolData = await Promise.all(
        slugs.map(async slug => {
          const res = await fetch(`/tool/${slug}/index.html`);
          const html = await res.text();
          return { slug, html };
        })
      );

      // Load full tool data from collection
      const fullData = await fetch('/api/tools.json').then(r => r.json());
      const selectedTools = slugs.map(slug => fullData.find(t => t.slug === slug)).filter(Boolean);

      // Fetch detailed tool data from the markdown content
      // Since we can't get the full Astro content on the client, we need the tools data embedded
      // Let's use a more detailed endpoint
      const detailRes = await fetch('/api/tools-detail.json');
      const detailData = await detailRes.json();
      const selectedDetails = slugs.map(slug => detailData.find(t => t.slug === slug)).filter(Boolean);

      renderComparison(selectedDetails);
    } catch (e) {
      results.innerHTML = `<p class="text-red-500 text-center py-8">Failed to load comparison data. Please try again.</p>`;
      results.classList.remove('hidden');
    }

    btn.textContent = 'Compare Now';
    btn.disabled = false;
  });

  function renderComparison(tools) {
    if (tools.length < 2) {
      results.innerHTML = `<p class="text-gray-500 text-center py-8">Select at least 2 tools to compare.</p>`;
      results.classList.remove('hidden');
      return;
    }

    const cols = tools.length;
    
    let html = `<div class="rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto -webkit-overflow-scrolling:touch">
      <table class="w-full text-sm min-w-[500px]">
        <thead class="bg-gray-50 dark:bg-gray-800/50">
          <tr>
            <th class="text-left px-4 py-3 font-medium text-gray-500 dark:text-gray-400 w-40">Feature</th>
            ${tools.map(t => `<th class="text-center px-4 py-3 font-semibold text-gray-900 dark:text-white">${escapeHtml(t.name)}</th>`).join('')}
          </tr>
        </thead>
        <tbody>`;

    // Category
    html += row('Category', tools.map(t => `<span class="text-xs px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-700">${escapeHtml(t.category)}</span>`));

    // Pricing
    html += row('Pricing', tools.map(t => {
      const p = t.pricing || '';
      const isFree = p.toLowerCase().includes('free');
      return `<span class="${isFree ? 'text-emerald-600 dark:text-emerald-400 font-medium' : ''}">${escapeHtml(p)}</span>`;
    }));

    // Rating
    html += row('Rating', tools.map(t => {
      const r = t.rating || 0;
      return `<span class="font-bold">${r}/5</span> ${'★'.repeat(Math.round(r))}`;
    }));

    // Description
    html += row('Description', tools.map(t => `<span class="text-gray-600 dark:text-gray-400">${escapeHtml(t.description)}</span>`));

    // Features (if available)
    if (tools.some(t => t.features && t.features.length)) {
      html += row('Top Features', tools.map(t => {
        if (!t.features || !t.features.length) return '<span class="text-gray-400">—</span>';
        return `<ul class="space-y-1">${t.features.slice(0, 5).map(f => `<li class="flex items-start gap-1"><span class="text-emerald-500 mt-0.5">✓</span> <span>${escapeHtml(f)}</span></li>`).join('')}</ul>`;
      }));
    }

    // Pros
    if (tools.some(t => t.pros && t.pros.length)) {
      html += row('Pros', tools.map(t => {
        if (!t.pros || !t.pros.length) return '<span class="text-gray-400">—</span>';
        return `<ul class="space-y-1">${t.pros.slice(0, 4).map(p => `<li class="flex items-start gap-1"><span class="text-emerald-500 mt-0.5">+</span> <span>${escapeHtml(p)}</span></li>`).join('')}</ul>`;
      }));
    }

    // Cons
    if (tools.some(t => t.cons && t.cons.length)) {
      html += row('Cons', tools.map(t => {
        if (!t.cons || !t.cons.length) return '<span class="text-gray-400">—</span>';
        return `<ul class="space-y-1">${t.cons.slice(0, 4).map(c => `<li class="flex items-start gap-1"><span class="text-red-500 mt-0.5">−</span> <span>${escapeHtml(c)}</span></li>`).join('')}</ul>`;
      }));
    }

    // Best for verdict
    if (tools.length >= 2) {
      const bestRated = tools.reduce((best, t) => (t.rating || 0) > (best.rating || 0) ? t : best);
      const bestFree = tools.filter(t => (t.pricing || '').toLowerCase().includes('free'))
                           .reduce((best, t) => (t.rating || 0) > (best.rating || 0) ? t : best, tools[0]);
      
      html += row('🏆 Verdict', tools.map(t => {
        const verdicts = [];
        if (t.slug === bestRated.slug) verdicts.push('Highest Rated');
        if (t.slug === bestFree.slug && t.pricing?.toLowerCase().includes('free')) verdicts.push('Best Free Option');
        return verdicts.length ? `<span class="text-xs font-medium px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">${verdicts.join(', ')}</span>` : '<span class="text-gray-400">—</span>';
      }));
    }

    // Pricing tiers
    if (tools.some(t => t.pricing_tiers && t.pricing_tiers.length)) {
      html += row('Pricing Tiers', tools.map(t => {
        if (!t.pricing_tiers || !t.pricing_tiers.length) return '<span class="text-gray-400">—</span>';
        return `<div class="space-y-2">${t.pricing_tiers.map(tier => 
          `<div class="text-xs p-2 rounded bg-gray-50 dark:bg-gray-800"><span class="font-medium">${escapeHtml(tier.name)}</span> — <span class="text-[#3B82F6]">${escapeHtml(tier.price)}</span></div>`
        ).join('')}</div>`;
      }));
    }

    html += `</tbody></table></div></div>`;

    // Add action buttons
    html += `<div class="mt-6 grid grid-cols-1 sm:grid-cols-${Math.min(cols, 3)} gap-3 sm:gap-4">
      ${tools.map(t => {
        const tool = window.__allTools?.find(x => x.slug === t.slug);
        const affUrl = tool?.affiliate_url;
        return `<a href="/tool/${t.slug}" class="btn-primary text-sm text-center py-2.5">View ${escapeHtml(t.name)} →</a>`;
      }).join('')}
    </div>`;

    results.innerHTML = html;
    results.classList.remove('hidden');
  }

  function row(label, cells) {
    const bg = 'border-t border-gray-100 dark:border-gray-700';
    return `<tr class="${bg}">
      <td class="px-4 py-3 font-medium text-gray-700 dark:text-gray-300 text-xs uppercase tracking-wider">${label}</td>
      ${cells.map(c => `<td class="px-4 py-3 align-top">${c}</td>`).join('')}
    </tr>`;
  }

  function escapeHtml(str) {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
})();
</script>
