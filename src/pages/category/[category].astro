---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  const categories = [...new Set(tools.map(t => t.data.category))];
  return categories.map(cat => ({
    params: { category: cat },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const tools = await getCollection('tools');
const filtered = tools.filter(t => t.data.category === category);

const categoryLabels: Record<string, string> = {
  writing: 'Writing & Content', image: 'Image Generation', video: 'Video Creation',
  audio: 'Audio & Voice', coding: 'Coding & Development', productivity: 'Productivity',
  data: 'Data & Analytics', design: 'Design & Creative', marketing: 'Marketing & SEO', business: 'Business & Finance',
};

const categoryEmojis: Record<string, string> = {
  writing: '✍️', image: '🎨', video: '🎬', audio: '🎵', coding: '💻',
  productivity: '⚡', data: '📊', design: '🎯', marketing: '📈', business: '💼',
};

const categoryDescriptions: Record<string, string> = {
  writing: 'AI writing assistants, content generators, and copywriting tools',
  image: 'AI image generators, art creators, and visual design tools',
  video: 'AI video creation, editing, and animation platforms',
  audio: 'AI voice generation, music creation, and audio editing',
  coding: 'AI code assistants, development tools, and debugging aids',
  productivity: 'AI productivity tools, automation, and workflow enhancement',
  data: 'AI analytics, data processing, and business intelligence tools',
  design: 'AI design tools for UI/UX, graphics, and creative work',
  marketing: 'AI marketing, SEO, and advertising optimization platforms',
  business: 'AI business tools for finance, operations, and management',
};

const label = categoryLabels[category] || category;

// Breadcrumb JSON-LD
const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aizest.net/" },
    { "@type": "ListItem", "position": 2, "name": `${label} AI Tools` }
  ]
});
---

<BaseLayout 
  title={`${label} AI Tools — Reviews & Comparisons — AI Zest`}
  description={`Browse ${label.toLowerCase()} AI tools — features, pricing, and comparisons. ${filtered.length} tools cataloged to help you find the right AI ${category} tool.`}
  canonical={`/category/${category}`}
>
  <script type="application/ld+json" set:html={breadcrumbJsonLd} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#3B82F6]">Home</a>
      <span>/</span>
      <span class="text-gray-900 dark:text-white font-medium">{label} AI Tools</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3">
        <span class="text-2xl sm:text-3xl">{categoryEmojis[category] || ''}</span>
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
            {label} AI Tools
          </h1>
          <p class="text-gray-500 dark:text-gray-400 mt-1">
            {categoryDescriptions[category] || ''}
          </p>
        </div>
      </div>
      <div class="mt-4 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
        {category === 'writing' && 'AI writing tools have transformed how content is created — from blog posts and social media captions to ad copy and email campaigns. This category covers everything from general-purpose AI assistants (ChatGPT, Claude) to specialized writing platforms (Jasper, Writesonic) and research tools (Perplexity, Gemini).'}
        {category === 'image' && 'AI image generation has advanced rapidly — from Midjourney\'s artistic quality to DALL-E 3\'s photorealistic output and Stable Diffusion\'s open-source flexibility. This category covers the leading AI image tools for creators, designers, and artists.'}
        {category === 'video' && 'AI video creation spans text-to-video generation (Runway, Pika), AI avatar presenters (Synthesia, HeyGen), and browser-based editors (VEED, CapCut). This category helps you choose the right tool for your video workflow.'}
        {category === 'audio' && 'AI audio tools cover voice synthesis (ElevenLabs), music generation (Suno), podcast production (Descript, Podcastle), and text-to-speech platforms. Find the right AI audio solution for your needs.'}
        {category === 'coding' && 'AI coding tools have become essential for developers — from AI pair programmers (GitHub Copilot, Cursor) to app builders (Bolt.new, Lovable) and code assistants (Claude Code). Find the best AI for your development workflow.'}
        {category === 'productivity' && 'AI productivity tools help streamline workflows — from AI-powered project management (Notion AI, ClickUp) to presentation creation (Gamma) and workflow automation (Zapier, Make). Boost your team\'s efficiency with the right AI tools.'}
        {category === 'data' && 'AI data tools help analysts and businesses process large datasets, generate insights, and create visualizations. This category covers AI-powered analytics platforms and data processing tools.'}
        {category === 'design' && 'AI design tools make professional design accessible to everyone — from all-in-one platforms (Canva) to UI/UX prototyping (Uizard) and specialized AI generators (Adobe Firefly, Recraft).'}
        {category === 'marketing' && 'AI marketing tools cover SEO analysis (Semrush, Ahrefs), content optimization (Surfer SEO), ad copy generation, and marketing automation. Build a complete AI-powered marketing stack.'}
        {category === 'business' && 'AI business tools help companies automate operations, generate leads, manage customer relationships, and analyze data. This category covers AI solutions for modern businesses.'}
      </div>

      <!-- Related Content Links -->
      <div class="flex flex-wrap items-center gap-2 mt-4">
        {(category === 'writing' || category === 'image' || category === 'video' || category === 'audio' || category === 'coding' || category === 'productivity' || category === 'data' || category === 'design' || category === 'marketing' || category === 'business') && (
          <>
            <span class="text-xs text-gray-400">Explore:</span>
            {category === 'writing' && <><a href="/best-ai-writing-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Writing Tools</a><a href="/free-ai-writing-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Writing Tools</a></>}
            {category === 'image' && <><a href="/best-ai-image-generators-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Image Generators</a><a href="/free-ai-image-generators-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Image Generators</a></>}
            {category === 'video' && <><a href="/best-ai-video-generators-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Video Generators</a><a href="/free-ai-video-generators-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Video Generators</a></>}
            {category === 'audio' && <><a href="/best-ai-audio-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Audio Tools</a><a href="/free-ai-audio-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Audio Tools</a></>}
            {category === 'coding' && <><a href="/best-ai-coding-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Coding Tools</a><a href="/free-ai-coding-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Coding Tools</a></>}
            {category === 'productivity' && <><a href="/best-ai-productivity-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Productivity Tools</a><a href="/free-ai-productivity-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Productivity Tools</a></>}
            {category === 'data' && <><a href="/best-ai-data-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Data Tools</a><a href="/free-ai-data-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Data Tools</a></>}
            {category === 'design' && <><a href="/best-ai-design-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Design Tools</a><a href="/free-ai-design-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Design Tools</a></>}
            {category === 'marketing' && <><a href="/best-ai-marketing-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Marketing Tools</a><a href="/free-ai-marketing-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Marketing Tools</a></>}
            {category === 'business' && <><a href="/best-ai-business-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">🏆 Best AI Business Tools</a><a href="/free-ai-business-tools-2026" class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">🆓 Free AI Business Tools</a></>}
          </>
        )}
      </div>
        <span class="font-medium text-gray-900 dark:text-white">{filtered.length} tools</span>
        <span>·</span>
        <button id="sort-rating" class="sort-btn text-[#3B82F6] font-medium cursor-pointer hover:underline" data-sort="rating">Highest Rated</button>
        <span>·</span>
        <button id="sort-name" class="sort-btn text-gray-500 dark:text-gray-400 cursor-pointer hover:text-gray-900 dark:hover:text-white" data-sort="name">A-Z</button>
      </div>
    </div>

    <!-- Tools grid -->
    {filtered.length > 0 ? (
      <>
        <div id="tool-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {filtered.map(tool => (
            <div class="tool-item" data-rating={tool.data.rating} data-name={tool.data.name}>
              <ToolCard tool={tool} />
            </div>
          ))}
        </div>

        <div class="mt-12 p-6 rounded-xl bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 text-center">
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
            Can't decide which tool is right for you?
          </p>
          <a href="/compare" class="btn-primary inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Compare Tools →
          </a>
        </div>
      </>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500 dark:text-gray-400">No tools in this category yet. Check back soon!</p>
      </div>
    )}
    
  </div>
</BaseLayout>

<script>
(function() {
  const grid = document.getElementById('tool-grid');
  if (!grid) return;

  function sortTools(by) {
    const items = [...grid.querySelectorAll('.tool-item')];
    items.sort((a, b) => {
      if (by === 'rating') return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
      return a.dataset.name.localeCompare(b.dataset.name);
    });
    items.forEach(item => grid.appendChild(item));

    document.querySelectorAll('.sort-btn').forEach(btn => {
      if (btn.dataset.sort === by) {
        btn.className = 'sort-btn text-[#3B82F6] font-medium cursor-pointer hover:underline';
      } else {
        btn.className = 'sort-btn text-gray-500 dark:text-gray-400 cursor-pointer hover:text-gray-900 dark:hover:text-white';
      }
    });
  }

  document.querySelectorAll('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => sortTools(btn.dataset.sort));
  });
})();
</script>
