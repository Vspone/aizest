    }
  ]
});

// Breadcrumb JSON-LD
const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aizest.net/" },
    { "@type": "ListItem", "position": 2, "name": "Best AI SEO Tools 2026" }
