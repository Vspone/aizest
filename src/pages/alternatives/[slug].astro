---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import AffiliateBtn from '../../components/AffiliateBtn.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map(tool => ({
    params: { slug: tool.data.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const allTools = await getCollection('tools');
const { name, slug, description, pricing, rating, category } = tool.data;

const categoryLabels: Record<string, string> = {
  writing: 'Writing & Content', image: 'Image Generation', video: 'Video Creation',
  audio: 'Audio & Voice', coding: 'Coding & Development', productivity: 'Productivity',
  data: 'Data & Analytics', design: 'Design & Creative', marketing: 'Marketing & SEO', business: 'Business & Finance',
};

// Get alternatives (same category, excluding current tool)
const alternatives = allTools
  .filter(t => t.data.category === category && t.data.slug !== slug)
  .sort((a, b) => (b.data.rating || 0) - (a.data.rating || 0));

const catName = categoryLabels[category] || category;

// Build FAQ for alternatives
const faqItems = [
  {
    name: `What are the best alternatives to ${name}?`,
    acceptedAnswer: `The best alternatives to ${name} include ${alternatives.slice(0, 3).map(t => t.data.name).join(', ')}. Each offers different strengths — see the comparison below for details.`
  },
  {
    name: `Is there a free alternative to ${name}?`,
    acceptedAnswer: `Some alternatives to ${name} may offer free tiers. Check the pricing column in the comparison table below to find tools with free plans.`
  },
  {
    name: `Which ${catName.toLowerCase()} tool is best for me?`,
    acceptedAnswer: `The best tool depends on your specific needs — budget, feature requirements, and use case. We recommend starting with free trials of the top-rated alternatives to find the best fit.`
  },
];

// JSON-LD
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `Top ${name} Alternatives 2026`,
  "description": `Explore the best alternatives to ${name}. Compare features, pricing, ratings, and find the perfect ${catName.toLowerCase()} tool for your needs.`,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": alternatives.slice(0, 10).map((t, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "SoftwareApplication",
        "name": t.data.name,
        "description": t.data.description
      }
    }))
  }
});

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems
});

const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aizest.net/" },
    { "@type": "ListItem", "position": 2, "name": `${name} Alternatives` }
  ]
});

const title = `Top ${name} Alternatives 2026 — AI Zest`;
const canonical = `/alternatives/${slug}`;
const pageDescription = `Looking for alternatives to ${name}? Compare ${alternatives.length} similar AI tools with ratings, pricing, and features. Find the best ${catName.toLowerCase()} tool for your needs.`;
const h1 = `Top ${name} Alternatives 2026`;
const toolDescription = description;
---

<BaseLayout title={title} description={pageDescription} canonical={canonical} jsonLd={jsonLd}>
  <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  <script type="application/ld+json" set:html={faqJsonLd} />

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#3B82F6]">Home</a>
      <span>/</span>
      <span class="text-gray-900 dark:text-white font-medium">{name} Alternatives</span>
    </nav>

    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3">{h1}</h1>
      <p class="text-gray-600 dark:text-gray-400 max-w-3xl">{pageDescription}</p>
    </div>

    <!-- Current tool summary -->
    <div class="mb-10 p-5 rounded-xl bg-blue-50 dark:bg-blue-900/10 border border-blue-100 dark:border-blue-900/20">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-lg shrink-0">🔍</span>
        <div>
          <span class="text-sm font-semibold text-gray-900 dark:text-white">{name}</span>
          <span class="text-xs text-gray-500 ml-2">{rating}/5 · {pricing}</span>
        </div>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400 ml-9">{toolDescription}</p>
      <div class="ml-9 mt-2">
        <a href={`/tool/${slug}`} class="text-sm text-[#3B82F6] hover:underline">Read full {name} review →</a>
      </div>
    </div>

    {alternatives.length > 0 ? (
      <>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Best {name} Alternatives</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">{alternatives.length} tools found in {catName}.</p>

        <!-- Comparison Table -->
        <div class="overflow-x-auto mb-10 rounded-xl border border-gray-200 dark:border-gray-700">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 dark:bg-gray-800">
                <th class="text-left p-3 font-semibold text-gray-900 dark:text-white">Tool</th>
                <th class="text-left p-3 font-semibold text-gray-900 dark:text-white">Category</th>
                <th class="text-center p-3 font-semibold text-gray-900 dark:text-white">Rating</th>
                <th class="text-center p-3 font-semibold text-gray-900 dark:text-white">Pricing</th>
                <th class="text-center p-3 font-semibold text-gray-900 dark:text-white">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              {alternatives.map(alt => (
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                  <td class="p-3">
                    <a href={`/tool/${alt.data.slug}`} class="font-medium text-gray-900 dark:text-white hover:text-[#3B82F6] transition-colors">
                      {alt.data.name}
                    </a>
                  </td>
                  <td class="p-3 text-gray-500 dark:text-gray-400">{categoryLabels[alt.data.category] || alt.data.category}</td>
                  <td class="p-3 text-center">
                    <span class="inline-flex items-center gap-1">
                      <span class="text-yellow-500">★</span>
                      <span class="text-gray-900 dark:text-gray-100">{alt.data.rating}</span>
                    </span>
                  </td>
                  <td class="p-3 text-center text-gray-500 dark:text-gray-400 text-xs">{alt.data.pricing}</td>
                  <td class="p-3 text-center">
                    <a href={`/tool/${alt.data.slug}`} class="text-xs text-[#3B82F6] hover:underline font-medium">
                      Review →
                    </a>
                    <AffiliateBtn slug={alt.data.slug} variant="small" />
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Individual alternatives details -->
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Detailed Comparison</h2>
        <div class="space-y-4 mb-10">
          {alternatives.slice(0, 8).map(alt => (
            <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-5 hover:border-[#3B82F6]/30 transition-colors">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <a href={`/tool/${alt.data.slug}`} class="text-base font-semibold text-gray-900 dark:text-white hover:text-[#3B82F6] transition-colors">
                    {alt.data.name}
                  </a>
                  <div class="flex items-center gap-3 mt-1">
                    <span class="text-xs text-yellow-600">★ {alt.data.rating}/5</span>
                    <span class="text-xs text-gray-400">·</span>
                    <span class="text-xs text-gray-500">{alt.data.pricing}</span>
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mt-2 leading-relaxed">{alt.data.description}</p>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <a href={`/tool/${alt.data.slug}`} class="btn-outline text-xs px-3 py-1.5">Review</a>
                  <AffiliateBtn slug={alt.data.slug} variant="small" />
                </div>
              </div>
            </div>
          ))}
        </div>

        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Categories</h2>
        <div class="flex flex-wrap gap-2 mb-10">
          <a href={`/category/${category}`} class="inline-block px-3 py-1.5 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs text-gray-700 dark:text-gray-300 hover:bg-[#3B82F6]/10 hover:text-[#3B82F6] transition-colors">
            All {catName} Tools →
          </a>
          <a href="/compare" class="inline-block px-3 py-1.5 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs text-gray-700 dark:text-gray-300 hover:bg-[#3B82F6]/10 hover:text-[#3B82F6] transition-colors">
            Compare Any Tools →
          </a>
          <a href="/how-we-review" class="inline-block px-3 py-1.5 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs text-gray-700 dark:text-gray-300 hover:bg-[#3B82F6]/10 hover:text-[#3B82F6] transition-colors">
            How We Review →
          </a>
        </div>

        <!-- FAQ Section -->
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Frequently Asked Questions</h2>
        <div class="space-y-3 mb-10">
          {faqItems.map(item => (
            <details class="group rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
              <summary class="flex items-center justify-between p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                <span class="text-sm font-medium text-gray-900 dark:text-white pr-4">{item.name}</span>
                <svg class="w-4 h-4 text-gray-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-4 pb-4">
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.acceptedAnswer}</p>
              </div>
            </details>
          ))}
        </div>
      </>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500 dark:text-gray-400">No alternatives found for {name}.</p>
        <a href="/compare" class="text-sm text-[#3B82F6] hover:underline mt-2 inline-block">Use our comparison tool →</a>
      </div>
    )}
  </div>
</BaseLayout>
