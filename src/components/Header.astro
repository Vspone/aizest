    -webkit-tap-highlight-color: rgba(59,130,246,0.15);
  }
  .dark .mobile-nav-link {
    color: #d1d5db;
  }
  .mobile-nav-link:hover {
    background-color: #f3f4f6;
    color: #111827;
  }
  .dark .mobile-nav-link:hover {
    background-color: #1f2937;
    color: #ffffff;
  }
