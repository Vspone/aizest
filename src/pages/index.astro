---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SearchBar from '../components/SearchBar.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ToolCard from '../components/ToolCard.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
const featuredTools = tools.filter(t => t.data.featured).slice(0, 12);

// "Just Added" - newest tools (by pubDate or just last ones added)
const justAdded = tools.slice(-4).reverse();

const categories = [
  { name: 'Writing & Content', icon: '✍️', slug: 'writing', color: 'bg-blue-100 text-blue-600' },
  { name: 'Image Generation', icon: '🎨', slug: 'image', color: 'bg-purple-100 text-purple-600' },
  { name: 'Video Creation', icon: '🎬', slug: 'video', color: 'bg-pink-100 text-pink-600' },
  { name: 'Audio & Voice', icon: '🎵', slug: 'audio', color: 'bg-green-100 text-green-600' },
  { name: 'Coding & Dev', icon: '💻', slug: 'coding', color: 'bg-cyan-100 text-cyan-600' },
  { name: 'Marketing & SEO', icon: '📈', slug: 'marketing', color: 'bg-orange-100 text-orange-600' },
  { name: 'Productivity', icon: '⚡', slug: 'productivity', color: 'bg-amber-100 text-amber-600' },
  { name: 'Data & Analytics', icon: '📊', slug: 'data', color: 'bg-indigo-100 text-indigo-600' },
  { name: 'Design & Creative', icon: '🎯', slug: 'design', color: 'bg-rose-100 text-rose-600' },
  { name: 'Business & Finance', icon: '💼', slug: 'business', color: 'bg-teal-100 text-teal-600' },
];

const toolCounts: Record<string, number> = {};
for (const t of tools) {
  toolCounts[t.data.category] = (toolCounts[t.data.category] || 0) + 1;
}
---

<BaseLayout title="Best AI Tools 2026: Honest Reviews & Comparisons | AI Zest"
  description="102+ AI tools tested and rated. Hands-on reviews, transparent methodology, and side-by-side comparisons. Find the best AI tools for writing, image, video, coding, and more in 2026.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <Hero count={tools.length} />
    
    <div class="mt-4 mb-16">
      <SearchBar />
    </div>

    <!-- Categories -->
    <section class="mb-16 reveal-on-scroll">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
          Browse by Category
        </h2>
        <span class="text-sm text-gray-500 dark:text-gray-400">
          {tools.length} tools across {categories.length} categories
        </span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger-grid">
        {categories.map(cat => (
          <CategoryCard 
            name={cat.name}
            icon={cat.icon}
            slug={cat.slug}
            count={toolCounts[cat.slug] || 0}
            color={cat.color}
          />
        ))}
      </div>
    </section>

    <!-- New This Week -->
    {justAdded.length > 0 && (
      <section class="mb-16 reveal-on-scroll">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
              New This Week
            </h2>
          </div>
          <span class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
            <span>📅</span> Updated daily
          </span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-grid">
          {justAdded.map(tool => (
            <ToolCard tool={tool} />
          ))}
        </div>
      </section>
    )}

    <!-- Featured Tools -->
    {featuredTools.length > 0 && (
      <section class="mb-16 reveal-on-scroll">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
            ★ Featured Picks
          </h2>
          <a href="/category/writing" class="text-sm text-[#3B82F6] hover:underline font-medium">
            View All Tools →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-grid">
          {featuredTools.map(tool => (
            <ToolCard tool={tool} />
          ))}
        </div>
      </section>
    )}

    <!-- Compare CTA -->
    <section class="mb-16 reveal-on-scroll">
