---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
---

<BaseLayout 
  title="Editorial Policy — AI Zest"
  description="Our editorial policy for AI Zest: content integrity, AI assistance disclosure, corrections policy, affiliate disclosure, and review update practices."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <!-- Breadcrumb -->
    <nav class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#3B82F6]">Home</a>
      <span>/</span>
      <span class="text-gray-900 dark:text-white font-medium">Editorial Policy</span>
    </nav>

    <!-- Hero -->
    <div class="text-center mb-10">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-[#3B82F6] to-[#8B5CF6] text-white text-2xl mb-4">
        📜
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-3">
        Editorial <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#3B82F6] to-[#8B5CF6]">Policy</span>
      </h1>
      <p class="text-base sm:text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Our commitment to transparency, integrity, and editorial independence — how we create, review, and maintain content on AI Zest.
      </p>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">Last updated: June 25, 2026</p>
    </div>

    <!-- Content Integrity -->
    <section class="mb-10">
      <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2 flex items-center gap-2">
          <span>🛡️</span> Content Integrity
        </h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
          We do not accept payment for positive reviews. Every tool on AI Zest is evaluated on its own merit based on objective criteria and thorough research. No tool, developer, or company can buy a favorable rating or placement.
        </p>
        <div class="p-4 rounded-xl bg-blue-50 dark:bg-blue-900/10 border border-blue-100 dark:border-blue-900/20">
          <p class="text-sm text-blue-700 dark:text-blue-300 flex items-start gap-2">
            <span class="shrink-0">✅</span>
            <span><strong>Sponsored content</strong> is clearly and conspicuously labeled as such. Any paid partnership or sponsored post will always be identified, so you know exactly what you're reading.</span>
          </p>
        </div>
      </div>
    </section>

    <!-- AI Assistance -->
    <section class="mb-10">
      <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2 flex items-center gap-2">
          <span>🤖</span> AI Assistance
        </h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
          We use AI tools to assist with research and content drafting, but every review, comparison, and article on AI Zest is reviewed and edited by a human editor before publication. A human makes the final call on all ratings, opinions, and editorial decisions.
        </p>
        <div class="p-4 rounded-xl bg-purple-50 dark:bg-purple-900/10 border border-purple-100 dark:border-purple-900/20">
          <p class="text-sm text-purple-700 dark:text-purple-300 flex items-start gap-2">
            <span class="shrink-0">💡</span>
            <span>We are transparent about AI use because we believe honesty matters. AI helps us scale our coverage in a fast-moving space, but it never replaces human judgment, testing, or editorial oversight.</span>
          </p>
        </div>
      </div>
    </section>

    <!-- Corrections -->
    <section class="mb-10">
      <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2 flex items-center gap-2">
          <span>✏️</span> Corrections
        </h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
          We strive for accuracy, but mistakes can happen. If an error is found — whether in a review, comparison, pricing detail, or any other content — we correct it promptly and transparently. Every correction is noted with the date it was made so readers can track changes.
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
          If you spot an error, please let us know at <a href="mailto:admin@aizest.net" class="text-[#3B82F6] hover:underline">admin@aizest.net</a>. We appreciate your help in keeping our content accurate and trustworthy.
        </p>
      </div>
    </section>

    <!-- Affiliate Disclosure -->
    <section class="mb-10">
      <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2 flex items-center gap-2">
          <span>🔗</span> Affiliate Disclosure
        </h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
          Some links on aizest.net are affiliate links. If you click on an affiliate link and make a purchase, we may earn a small commission at no extra cost to you. We participate in affiliate programs including <strong>Awin</strong> and other networks.
        </p>
        <div class="p-4 rounded-xl bg-amber-50 dark:bg-amber-900/10 border border-amber-100 dark:border-amber-900/20">
          <p class="text-sm text-amber-700 dark:text-amber-300 flex items-start gap-2">
            <span class="shrink-0">⚖️</span>
            <span><strong>Affiliate commissions do not affect our ratings, reviews, or recommendations.</strong> We evaluate every tool solely on its merits. Our editorial independence is non-negotiable — we recommend tools we genuinely believe in, regardless of affiliate relationships.</span>
          </p>
        </div>
      </div>
    </section>

    <!-- Review Updates -->
    <section class="mb-10">
      <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2 flex items-center gap-2">
          <span>🔄</span> Review Updates
        </h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
          AI tools change rapidly — features are added, pricing shifts, and new competitors emerge. We review and update our content regularly to keep it accurate and relevant. Each tool page includes a <strong>"last verified"</strong> date so you know how current the information is.
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
          If a tool undergoes significant changes — a major version release, pricing overhaul, or notable shift in quality — we prioritize updating its review. Older content is flagged for review on a recurring basis to ensure nothing falls out of date.
        </p>
      </div>
    </section>

    <!-- Contact -->
    <section class="mb-10">
      <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <span>📬</span> Contact
        </h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
          If you have questions about this editorial policy, want to report an error, or have concerns about any content on AI Zest, please reach out:
        </p>
        <div class="flex items-center gap-3 p-4 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-100 dark:border-gray-700">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[#3B82F6] to-[#8B5CF6] flex items-center justify-center text-white text-base shrink-0">
            ✉️
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900 dark:text-white">Email</p>
            <a href="mailto:admin@aizest.net" class="text-sm text-[#3B82F6] hover:underline">admin@aizest.net</a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-gradient-to-br from-[#3B82F6]/5 to-[#8B5CF6]/5 dark:from-[#3B82F6]/10 dark:to-[#8B5CF6]/10 p-8 sm:p-10 text-center">
      <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Trust Matters</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-5 max-w-md mx-auto">
        We believe transparency builds trust. Browse {tools.length} AI tool reviews you can rely on.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/" class="inline-flex items-center gap-2 btn-primary text-sm px-6 py-2.5">Browse All Tools</a>
        <a href="/how-we-review" class="inline-flex items-center gap-2 text-sm px-6 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:border-[#3B82F6]/40 transition-colors">How We Review</a>
      </div>
    </div>

  </div>
</BaseLayout>
