---
export interface Props {
  name: string;
  icon: string;
  slug: string;
  count: number;
  color: string;
}

const { name, icon, slug, count, color } = Astro.props;
---

<a href={`/category/${slug}`} class="card p-6 flex items-center gap-4 group hover:-translate-y-1 hover:shadow-lg transition-all duration-200">
  <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-xl ${color}`}>
    {icon}
  </div>
  <div class="flex-1 min-w-0">
    <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">
      {name}
    </h3>
    <p class="text-sm text-gray-500 dark:text-gray-400">{count} tools</p>
  </div>
  <svg class="w-5 h-5 text-gray-400 group-hover:text-[#3B82F6] transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
  </svg>
</a>
