<script>
(function() {
  'use strict';

  // ===== Scroll-Reveal: fade in sections as they enter viewport =====
  var revealEls = document.querySelectorAll('.reveal-on-scroll');
  if (revealEls.length > 0 && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    revealEls.forEach(function(el) { observer.observe(el); });
  } else {
    // Fallback: show everything immediately if no IO support
    revealEls.forEach(function(el) { el.classList.add('revealed'); });
  }

  // ===== Stats Counter: animate numbers =====
  var statTools = document.getElementById('stat-tools');
  var statCats = document.getElementById('stat-categories');
  if (statTools && statCats && 'IntersectionObserver' in window) {
    var statsGrid = document.getElementById('stats-grid');
    var counted = false;

    var statsObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !counted) {
          counted = true;
          statsObserver.unobserve(entry.target);

          var targetTools = parseInt(statTools.getAttribute('data-count'), 10);
          var targetCats = parseInt(statCats.getAttribute('data-count'), 10);
          var duration = 800; // ms
          var startTime = performance.now();

          function easeOutCubic(t) {
            return 1 - Math.pow(1 - t, 3);
          }

          function update() {
            var elapsed = performance.now() - startTime;
            var progress = Math.min(elapsed / duration, 1);
            var eased = easeOutCubic(progress);

            statTools.textContent = Math.round(eased * targetTools) + '+';
            statCats.textContent = Math.round(eased * targetCats);

            if (progress < 1) {
              requestAnimationFrame(update);
            } else {
              statTools.textContent = targetTools + '+';
              statCats.textContent = targetCats;
            }
          }

          update();
        }
      });
    }, { threshold: 0.3 });

    statsObserver.observe(statsGrid);
  } else if (statTools && statCats) {
    // No IO support: show final values immediately
    statTools.textContent = statTools.getAttribute('data-count') + '+';
    statCats.textContent = statCats.getAttribute('data-count');
  }
})();
</script>
