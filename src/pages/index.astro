---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SearchBar from '../components/SearchBar.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ToolCard from '../components/ToolCard.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
const featuredTools = tools.filter(t => t.data.featured).slice(0, 6);

// "Just Added" - newest tools (by pubDate or just last ones added)
const justAdded = tools.slice(-4).reverse();

const categories = [
  { name: 'Writing & Content', icon: '✍️', slug: 'writing', color: 'bg-blue-100 text-blue-600' },
  { name: 'Image Generation', icon: '🎨', slug: 'image', color: 'bg-purple-100 text-purple-600' },
  { name: 'Video Creation', icon: '🎬', slug: 'video', color: 'bg-pink-100 text-pink-600' },
  { name: 'Audio & Voice', icon: '🎵', slug: 'audio', color: 'bg-green-100 text-green-600' },
  { name: 'Coding & Dev', icon: '💻', slug: 'coding', color: 'bg-cyan-100 text-cyan-600' },
  { name: 'Marketing & SEO', icon: '📈', slug: 'marketing', color: 'bg-orange-100 text-orange-600' },
  { name: 'Productivity', icon: '⚡', slug: 'productivity', color: 'bg-amber-100 text-amber-600' },
  { name: 'Data & Analytics', icon: '📊', slug: 'data', color: 'bg-indigo-100 text-indigo-600' },
  { name: 'Design & Creative', icon: '🎯', slug: 'design', color: 'bg-rose-100 text-rose-600' },
  { name: 'Business & Finance', icon: '💼', slug: 'business', color: 'bg-teal-100 text-teal-600' },
];

const toolCounts: Record<string, number> = {};
for (const t of tools) {
  toolCounts[t.data.category] = (toolCounts[t.data.category] || 0) + 1;
}
---

<BaseLayout title="AI Zest — Discover the Best AI Tools">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <Hero />
    
    <div class="mt-4 mb-16">
      <SearchBar />
    </div>

    <!-- Categories -->
    <section class="mb-16 reveal-on-scroll">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
          Browse by Category
        </h2>
        <span class="text-sm text-gray-500 dark:text-gray-400">
          {tools.length} tools across {categories.length} categories
        </span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.map(cat => (
          <CategoryCard 
            name={cat.name}
            icon={cat.icon}
            slug={cat.slug}
            count={toolCounts[cat.slug] || 0}
            color={cat.color}
          />
        ))}
      </div>
    </section>

    <!-- Just Added -->
    {justAdded.length > 0 && (
      <section class="mb-16 reveal-on-scroll">
        <div class="flex items-center gap-2 mb-6">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
            Just Added
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {justAdded.map(tool => (
            <ToolCard tool={tool} />
          ))}
        </div>
      </section>
    )}

    <!-- Featured Tools -->
    {featuredTools.length > 0 && (
      <section class="mb-16 reveal-on-scroll">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
            ★ Featured Picks
          </h2>
          <a href="/category/writing" class="text-sm text-[#3B82F6] hover:underline font-medium">
            View All Tools →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTools.map(tool => (
            <ToolCard tool={tool} />
          ))}
        </div>
      </section>
    )}

    <!-- Compare CTA -->
    <section class="mb-16 reveal-on-scroll">
      <a href="/compare" class="group block rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden hover:border-[#3B82F6]/30 dark:hover:border-[#3B82F6]/30 hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
        <div class="py-8 px-8 bg-gradient-to-br from-[#3B82F6]/5 to-[#8B5CF6]/5 dark:from-[#3B82F6]/10 dark:to-[#8B5CF6]/10 cta-breathe">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
            <div>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
                <span>⚖️</span> Compare AI Tools Side by Side
              </h2>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                Pick any two tools and compare features, pricing, and ratings — all in one view.
              </p>
            </div>
            <span class="btn-primary text-sm shrink-0 group-hover:translate-x-0.5 transition-transform">
              Start Comparing →
            </span>
          </div>
        </div>
      </a>
    </section>

    <!-- Articles & Reviews -->
    <section class="mb-16 reveal-on-scroll">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
          📝 Articles & Reviews
        </h2>
        <span class="text-sm text-gray-500 dark:text-gray-400">
          In-depth comparisons & guides
        </span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/best-ai-marketing-tools-2026" class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 article-card">
          <span class="text-lg shrink-0">📈</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">Best AI Marketing Tools 2026</div>
