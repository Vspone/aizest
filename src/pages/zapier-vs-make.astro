const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which is better — Zapier or Make?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on your needs. Zapier is considered the better choice for beginners and non-technical users who need quick automations with 8,000+ app integrations. Make is better for technical users who need complex multi-branch workflows, visual scenario building, and substantially lower cost at scale — often one-seventh the price of Zapier for the same volume of executions."
      }
