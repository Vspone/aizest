---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  tool: CollectionEntry<'tools'>;
}

const { tool } = Astro.props;
const { name, description, category, rating, pricing, slug, featured, affiliate_url } = tool.data;

const categoryLabels: Record<string, string> = {
  writing: 'Writing', image: 'Image', video: 'Video', audio: 'Audio',
  coding: 'Coding', productivity: 'Productivity', data: 'Data',
  design: 'Design', marketing: 'Marketing', business: 'Business',
};

const categoryColors: Record<string, string> = {
  writing: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
  image: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400',
  video: 'bg-pink-100 text-pink-700 dark:bg-pink-900/30 dark:text-pink-400',
  audio: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
  coding: 'bg-cyan-100 text-cyan-700 dark:bg-cyan-900/30 dark:text-cyan-400',
  productivity: 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400',
  data: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400',
  design: 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400',
  marketing: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400',
  business: 'bg-teal-100 text-teal-700 dark:bg-teal-900/30 dark:text-teal-400',
};

// Derive pricing badge from pricing string
function getPricingBadge(p: string): { label: string; class: string } {
  const lower = p.toLowerCase();
  if (lower.includes('free')) return { label: 'Free', class: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' };
  if (lower.includes('freemium')) return { label: 'Freemium', class: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' };
  if (lower.includes('trial')) return { label: 'Free Trial', class: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400' };
  return { label: 'Paid', class: 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300' };
}

const priceBadge = getPricingBadge(pricing);
const stars = Math.round(rating);
const fullStars = stars;
const hasHalf = rating - stars >= 0.25;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

// Tool initials for the icon placeholder
const initials = name.split(' ').slice(0, 2).map(w => w[0]).join('').toUpperCase().slice(0, 2);
const iconColors = [
  'from-blue-500 to-blue-600', 'from-purple-500 to-purple-600', 'from-pink-500 to-pink-600',
  'from-cyan-500 to-cyan-600', 'from-amber-500 to-amber-600', 'from-rose-500 to-rose-600',
  'from-emerald-500 to-emerald-600', 'from-indigo-500 to-indigo-600', 'from-orange-500 to-orange-600',
];
const iconColor = iconColors[name.length % iconColors.length];
---

<a href={`/tool/${slug}`} class="group block rounded-xl border border-gray-200 dark:border-gray-700 
        bg-white dark:bg-gray-800 p-5 hover:shadow-xl hover:-translate-y-1 hover:border-[#3B82F6]/30 
        dark:hover:border-[#3B82F6]/40 transition-all duration-200">

  <!-- Top row: icon + name + category -->
  <div class="flex items-start gap-3 mb-3">
    <div class={`w-10 h-10 rounded-lg bg-gradient-to-br ${iconColor} flex items-center justify-center text-white font-bold text-sm shrink-0`}>
      {initials}
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">
        {name}
      </h3>
      <div class="flex items-center gap-1.5 mt-1 flex-wrap">
        <span class={`text-xs px-1.5 py-0.5 rounded ${categoryColors[category] || 'bg-gray-100 text-gray-700'}`}>
          {categoryLabels[category] || category}
        </span>
        {featured && (
          <span class="text-xs px-1.5 py-0.5 rounded bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">
            ★ Featured
          </span>
        )}
      </div>
    </div>
  </div>

  <!-- Description -->
  <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-3 leading-relaxed">
    {description}
  </p>

  <!-- Bottom row: pricing badge + stars + action -->
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <!-- Pricing badge -->
      <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${priceBadge.class}`}>
        {priceBadge.label}
      </span>
      <!-- Stars -->
      <div class="flex items-center gap-0.5">
        {Array.from({ length: fullStars }).map((_, i) => (
          <svg key={`full-${i}`} class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
        {hasHalf && (
          <svg class="w-3.5 h-3.5 text-yellow-400" viewBox="0 0 20 20">
            <defs><linearGradient id="half-star"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="#d1d5db"/></linearGradient></defs>
            <path fill="url(#half-star)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        )}
        {Array.from({ length: emptyStars }).map((_, i) => (
          <svg key={`empty-${i}`} class="w-3.5 h-3.5 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
        <span class="text-xs text-gray-400 ml-0.5">{rating}</span>
      </div>
    </div>
    <!-- Action button -->
    <span class="text-xs font-medium text-[#3B82F6] group-hover:translate-x-0.5 transition-transform flex items-center gap-0.5">
      {affiliate_url ? 'Visit' : 'Review'}
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
