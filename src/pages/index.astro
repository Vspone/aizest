            <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">Best AI Video Generators 2026</div>
            <div class="text-xs text-gray-500 dark:text-gray-400 truncate">Runway, Synthesia, HeyGen & CapCut</div>
          </div>
          <span class="text-xs text-[#3B82F6] shrink-0 group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
        <a href="/best-ai-image-generators-2026" class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 article-card">
          <span class="text-lg shrink-0">🎨</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">Best AI Image Generators 2026</div>
            <div class="text-xs text-gray-500 dark:text-gray-400 truncate">Midjourney, DALL-E 3, Ideogram & more</div>
          </div>
          <span class="text-xs text-[#3B82F6] shrink-0 group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
        <a href="/best-ai-audio-tools-2026" class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 article-card">
          <span class="text-lg shrink-0">🎵</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">Best AI Audio Tools 2026</div>
            <div class="text-xs text-gray-500 dark:text-gray-400 truncate">ElevenLabs, Descript, Suno & Murf</div>
          </div>
          <span class="text-xs text-[#3B82F6] shrink-0 group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
        <a href="/best-free-ai-tools-2026" class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 article-card">
          <span class="text-lg shrink-0">🆓</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">Best Free AI Tools 2026</div>
            <div class="text-xs text-gray-500 dark:text-gray-400 truncate">Top free AI tools across every category</div>
          </div>
          <span class="text-xs text-[#3B82F6] shrink-0 group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
        <a href="/chatgpt-vs-claude-vs-gemini" class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 article-card">
          <span class="text-lg shrink-0">🤖</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">ChatGPT vs Claude vs Gemini</div>
            <div class="text-xs text-gray-500 dark:text-gray-400 truncate">Which AI assistant is best in 2026?</div>
          </div>
          <span class="text-xs text-[#3B82F6] shrink-0 group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
        <a href="/midjourney-vs-dalle-vs-stable-diffusion" class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 article-card">
          <span class="text-lg shrink-0">🖼️</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">Midjourney vs DALL-E 3 vs SD</div>
            <div class="text-xs text-gray-500 dark:text-gray-400 truncate">Best AI image generator showdown</div>
          </div>
          <span class="text-xs text-[#3B82F6] shrink-0 group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
        <a href="/jasper-vs-writesonic-vs-copyai" class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 article-card">
          <span class="text-lg shrink-0">📝</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">Jasper vs Writesonic vs Copy.ai</div>
            <div class="text-xs text-gray-500 dark:text-gray-400 truncate">Best AI writing tool for your needs</div>
          </div>
          <span class="text-xs text-[#3B82F6] shrink-0 group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
      </div>
    </section>

    <!-- Stats + Newsletter combo -->
    <section class="mb-16 reveal-on-scroll">
      <div class="rounded-2xl border border-gray-200 dark:border-gray-800 overflow-hidden">
        <div class="py-10 px-8 bg-gradient-to-br from-[#3B82F6]/5 to-[#8B5CF6]/5 dark:from-[#3B82F6]/10 dark:to-[#8B5CF6]/10">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8 text-center mb-6 sm:mb-10" id="stats-grid">
            <div>
              <div class="text-2xl sm:text-3xl font-bold text-[#3B82F6]" id="stat-tools" data-count={tools.length}>0</div>
              <div class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 mt-1">AI Tools Reviewed</div>
            </div>
            <div>
              <div class="text-2xl sm:text-3xl font-bold text-[#8B5CF6]" id="stat-categories" data-count={categories.length}>0</div>
              <div class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 mt-1">Categories</div>
            </div>
            <div>
              <div class="text-2xl sm:text-3xl font-bold text-[#3B82F6]">2026</div>
              <div class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 mt-1">Continuously Updated</div>
            </div>
          </div>

          <div class="max-w-lg mx-auto text-center">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Stay Updated</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Get new AI tools and reviews delivered to your inbox.</p>
            <div class="ml-embedded" data-form="J0miZX"></div>
          </div>

        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
(function() {
  'use strict';

  // ===== Scroll-Reveal: fade in sections as they enter viewport =====
  var revealEls = document.querySelectorAll('.reveal-on-scroll');
  if (revealEls.length > 0 && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    revealEls.forEach(function(el) { observer.observe(el); });
  } else {
    // Fallback: show everything immediately if no IO support
    revealEls.forEach(function(el) { el.classList.add('revealed'); });
  }

  // ===== Stats Counter: animate numbers =====
  var statTools = document.getElementById('stat-tools');
  var statCats = document.getElementById('stat-categories');
  if (statTools && statCats && 'IntersectionObserver' in window) {
    var statsGrid = document.getElementById('stats-grid');
    var counted = false;

    var statsObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !counted) {
          counted = true;
          statsObserver.unobserve(entry.target);

          var targetTools = parseInt(statTools.getAttribute('data-count'), 10);
          var targetCats = parseInt(statCats.getAttribute('data-count'), 10);
          var duration = 800; // ms
          var startTime = performance.now();

          function easeOutCubic(t) {
            return 1 - Math.pow(1 - t, 3);
          }

          function update() {
            var elapsed = performance.now() - startTime;
            var progress = Math.min(elapsed / duration, 1);
            var eased = easeOutCubic(progress);

            statTools.textContent = Math.round(eased * targetTools) + '+';
            statCats.textContent = Math.round(eased * targetCats);

            if (progress < 1) {
              requestAnimationFrame(update);
            } else {
              statTools.textContent = targetTools + '+';
              statCats.textContent = targetCats;
            }
          }

          update();
        }
      });
    }, { threshold: 0.3 });

    statsObserver.observe(statsGrid);
  } else if (statTools && statCats) {
    // No IO support: show final values immediately
    statTools.textContent = statTools.getAttribute('data-count') + '+';
    statCats.textContent = statCats.getAttribute('data-count');
  }
})();
</script>
