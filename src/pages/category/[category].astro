---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const tools = await getCollection('tools');
  const categories = [...new Set(tools.map(t => t.data.category))];
  return categories.map(cat => ({
    params: { category: cat },
    props: { category: cat },
  }));
}
const { category } = Astro.props;
const tools = await getCollection('tools');
const filtered = tools.filter(t => t.data.category === category);

const categoryLabels: Record<string, string> = {
  writing: 'Writing & Content', image: 'Image Generation', video: 'Video Creation',
  audio: 'Audio & Voice', coding: 'Coding & Development', productivity: 'Productivity',
  data: 'Data & Analytics', design: 'Design & Creative', marketing: 'Marketing & SEO', business: 'Business & Finance',
};
---

<BaseLayout title={`${categoryLabels[category] || category} AI Tools — AI Zest`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <div class="mb-8">
      <a href="/" class="text-sm text-gray-500 dark:text-gray-400 hover:text-[#3B82F6]">← Back to Home</a>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mt-2">
        {categoryLabels[category] || category} AI Tools
      </h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">
        {filtered.length} tools found
      </p>
    </div>

    {filtered.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {filtered.map(tool => <ToolCard tool={tool} />)}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500 dark:text-gray-400">No tools in this category yet. Check back soon!</p>
      </div>
    )}
    
  </div>
</BaseLayout>
