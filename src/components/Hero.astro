---
export interface Props {
  count?: number;
}
const { count = 100 } = Astro.props;
---

<div class="text-center py-12 sm:py-16 md:py-24">
  <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold text-gray-900 dark:text-white leading-tight">
    <span class="hero-word" style="animation-delay:0.05s">Honest</span>
    <span class="hero-word" style="animation-delay:0.15s">AI</span>
    <span class="hero-word" style="animation-delay:0.25s">Tool</span>
    <span class="block text-transparent bg-clip-text bg-gradient-to-r from-[#3B82F6] via-[#6B5CF6] to-[#8B5CF6] hero-word-shimmer mt-1">
      Reviews & Comparisons
    </span>
  </h1>
  <p class="mt-3 sm:mt-4 text-base sm:text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto px-4 animate-fade-in-up-slow" style="opacity: 0">
    {count}+ AI tools tested and rated. Hands-on reviews, transparent methodology, and side-by-side comparisons — no hype, just honest assessments.
  </p>
</div>
