  "@type": "Article",
  "headline": "Best Free AI Tools 2026",
  "description": description,
  "datePublished": "2026-06-20",
  "dateModified": "2026-06-20",
  "author": {
    "@type": "Organization",
    "name": "AI Zest"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AI Zest"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://aizest.net${canonical}`
  }
});

// FAQ JSON-LD
const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the best free AI tool overall?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ChatGPT offers the most versatile free AI tool with powerful conversation, writing, coding, and analysis capabilities. For specific tasks, Cursor (coding), Canva (design), and CapCut (video editing) are the best in their categories."
      }
    },
    {
