---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map(tool => ({
    params: { slug: tool.data.slug },
    props: { tool },
  }));
}
const { tool } = Astro.props;
const { Content } = await render(tool);
const { name, slug, description, website, pricing, affiliate_url, rating, features, pricing_tiers, pros, cons, category, needs_vps } = tool.data;

// Get all tools for alternatives section
const allTools = await getCollection('tools');
const alternatives = allTools
  .filter(t => t.data.category === category && t.data.slug !== slug)
  .slice(0, 4);

// Determine best CTA text based on pricing
function ctaText(p: string): string {
  const lower = p.toLowerCase();
  if (lower.includes('free')) return 'Try Free';
  if (lower.includes('trial')) return 'Start Free Trial';
  return 'Get Started';
}

const categoryLabels: Record<string, string> = {
  writing: 'Writing & Content', image: 'Image Generation', video: 'Video Creation',
  audio: 'Audio & Voice', coding: 'Coding & Development', productivity: 'Productivity',
  data: 'Data & Analytics', design: 'Design & Creative', marketing: 'Marketing & SEO', business: 'Business & Finance',
};

// Build FAQ data programmatically
const pricingSummary = pricing_tiers && pricing_tiers.length > 0
  ? pricing_tiers.map(t => `${t.name} — ${t.price}`).join(', ')
  : pricing;

const topFeatures = features.slice(0, 3).join(', ');

const faqItems = [
  {
    name: `What is ${name}?`,
    acceptedAnswer: { text: `${name} is an AI tool in the ${categoryLabels[category] || category} category. ${description}` }
  },
  {
    name: `How much does ${name} cost?`,
    acceptedAnswer: { text: pricing_tiers && pricing_tiers.length > 0 ? `${name} offers ${pricing_tiers.length} pricing tiers: ${pricingSummary}. ${pricing_tiers[0].features.slice(0, 2).join('. ')}.` : `${name} is priced at ${pricing}.` }
  },
  {
    name: `What are the main features of ${name}?`,
    acceptedAnswer: { text: `Key features of ${name} include: ${topFeatures}. For a complete list, see the features section above.` }
  },
  {
    name: `What are the pros and cons of ${name}?`,
    acceptedAnswer: { text: pros && cons ? `Pros include: ${pros.slice(0, 2).join(', ')}. Cons include: ${cons.slice(0, 2).join(', ')}. See the full pros/cons breakdown above.` : `${name} is rated ${rating}/5. Check the pros and cons section above for a detailed breakdown.` }
  },
  {
    name: `Is ${name} worth it?`,
    acceptedAnswer: { text: `${name} has a rating of ${rating}/5 on AI Zest. ${rating >= 4.5 ? 'It is highly rated and considered one of the best tools in its category.' : rating >= 4.0 ? 'It is a solid choice with good reviews from users.' : 'It has average ratings — consider trying the free tier first.'} Visit the official website to explore pricing and start a free trial if available.` }
  },
];

// JSON-LD SoftwareApplication Schema
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": name,
  "description": description,
  "url": website,
  "applicationCategory": categoryLabels[category] || category,
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": pricing.replace(/^Free\s*\/\s*/, '').replace(/^From\s*/, '').trim() || 'Free',
    "priceCurrency": "USD",
    "priceValidUntil": "2027-12-31"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": rating,
    "bestRating": 5,
    "ratingCount": 1
  }
});

// FAQPage JSON-LD for rich snippets
const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems
});

// Breadcrumb JSON-LD
const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aizest.net/" },
    { "@type": "ListItem", "position": 2, "name": categoryLabels[category] || category, "item": `https://aizest.net/category/${category}` },
    { "@type": "ListItem", "position": 3, "name": name }
  ]
});
---

<BaseLayout 
  title={`${name} Review 2026 — Pricing, Features & Rating — AI Zest`}
  description={`${name} review: ${description}. Pricing: ${pricing}. Rating: ${rating}/5. Compare features, pros, cons, alternatives, and find the best AI tool for your needs.`}
  canonical={`/tool/${slug}`}
  type="article"
  jsonLd={jsonLd}
>
  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  <!-- FAQ JSON-LD -->
  <script type="application/ld+json" set:html={faqJsonLd} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <!-- Breadcrumb -->
    <nav class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#3B82F6]">Home</a>
      <span>/</span>
      <a href={`/category/${category}`} class="hover:text-[#3B82F6]">{categoryLabels[category] || category}</a>
      <span>/</span>
      <span class="text-gray-900 dark:text-white font-medium truncate">{name}</span>
    </nav>

    <!-- Header -->
    <div class="mt-6 mb-8 sm:mb-10">
      <div class="flex items-start gap-4 flex-wrap">
        <div>
          <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">{name}</h1>
          <p class="text-base sm:text-lg text-gray-600 dark:text-gray-400 mt-2">{description}</p>
        </div>
      </div>
      
      <div class="flex flex-wrap items-center gap-3 mt-4">
        <span class={`badge ${
          category === 'writing' ? 'bg-blue-100 text-blue-700' :
          category === 'image' ? 'bg-purple-100 text-purple-700' :
          category === 'video' ? 'bg-pink-100 text-pink-700' :
          'bg-gray-100 text-gray-700'
        }`}>
          {categoryLabels[category] || category}
        </span>
        <div class="flex items-center" itemscope itemtype="https://schema.org/AggregateRating">
          <meta itemprop="ratingValue" content={String(rating)} />
          <meta itemprop="bestRating" content="5" />
          {[1,2,3,4,5].map(i => (
            <svg key={i} class={`w-5 h-5 ${i <= Math.round(rating) ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600'}`} fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
          <span class="ml-1.5 text-sm text-gray-500">({rating}/5)</span>
        </div>
        <span class="text-sm text-gray-500" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <span itemprop="price">{pricing}</span>
        </span>
      </div>
    </div>

    <!-- CTA -->
    {affiliate_url && (
      <div class="mb-8 sm:mb-10 p-5 sm:p-6 rounded-xl bg-gradient-to-r from-[#3B82F6]/10 to-[#8B5CF6]/10 border border-[#3B82F6]/20 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
          Ready to try {name}?
        </p>
        <a href={affiliate_url} target="_blank" rel="noopener noreferrer" class="btn-primary w-full sm:w-auto px-8 py-3">
          {ctaText(pricing)} →
        </a>
        <p class="text-xs text-gray-500 mt-2">Affiliate link. We may earn a commission.</p>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Main Content -->
      <div class="md:col-span-2 space-y-8">
        
        <!-- Features -->
        <section>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Key Features</h2>
          <ul class="space-y-3">
            {features.map(f => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700 dark:text-gray-300">{f}</span>
              </li>
            ))}
          </ul>
        </section>

        <!-- Pros/Cons -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <section class="p-5 rounded-xl bg-green-50 dark:bg-green-900/10 border border-green-100 dark:border-green-900/20">
            <h3 class="font-semibold text-green-800 dark:text-green-400 mb-3">✅ Pros</h3>
            <ul class="space-y-2">
              {pros.map(p => (
                <li class="text-sm text-gray-700 dark:text-gray-300">• {p}</li>
              ))}
            </ul>
          </section>
          <section class="p-5 rounded-xl bg-red-50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/20">
            <h3 class="font-semibold text-red-800 dark:text-red-400 mb-3">❌ Cons</h3>
            <ul class="space-y-2">
              {cons.map(c => (
                <li class="text-sm text-gray-700 dark:text-gray-300">• {c}</li>
              ))}
            </ul>
          </section>
        </div>

        <!-- Body content -->
        <section class="prose prose-gray dark:prose-invert max-w-none">
          <Content />
        </section>

        <!-- FAQ Section -->
        <section class="not-prose mt-10">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map((item, i) => (
              <details class="group rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                <summary class="flex items-center justify-between p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                  <span class="text-sm font-medium text-gray-900 dark:text-white pr-4">{item.name}</span>
                  <svg class="w-4 h-4 text-gray-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-4 pb-4">
                  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.acceptedAnswer.text}</p>
                </div>
              </details>
            ))}
          </div>
        </section>

        <!-- Alternatives Section -->
        {alternatives.length > 0 && (
          <section class="not-prose mt-10">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">{name} Alternatives</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Explore other AI tools in the {categoryLabels[category] || category} category similar to {name}.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {alternatives.map(alt => (
                <a href={`/tool/${alt.data.slug}`} class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200">
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors truncate">{alt.data.name}</div>
                    <div class="text-xs text-gray-500 dark:text-gray-400 truncate">{alt.data.rating}/5 · {alt.data.pricing}</div>
                  </div>
                  <span class="text-xs text-[#3B82F6] shrink-0 group-hover:translate-x-0.5 transition-transform">→</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Related Articles -->
        <div class="not-prose mt-10 p-5 rounded-xl bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-3 text-sm">📄 Related Articles</h3>
          <div class="space-y-2">
            <a href={`/alternatives/${slug}`} class="block text-sm text-[#3B82F6] hover:underline">Top {name} Alternatives →</a>
            <a href="/compare" class="block text-sm text-[#3B82F6] hover:underline">Compare {name} with similar tools →</a>
            <a href="/how-we-review" class="block text-sm text-[#3B82F6] hover:underline">How we test and review AI tools →</a>
          </div>
        </div>

        <!-- VPS Recommendation (for self-hostable/deployable tools) -->
        {needs_vps && (
        <div class="not-prose mt-8 p-5 rounded-xl bg-gradient-to-br from-[#0D9488]/5 to-[#0891B2]/5 dark:from-[#0D9488]/10 dark:to-[#0891B2]/10 border border-gray-200 dark:border-gray-700">
          <div class="flex items-start gap-3 sm:gap-4">
            <span class="text-xl shrink-0 mt-0.5">☁️</span>
            <div>
              <p class="font-semibold text-gray-900 dark:text-white text-sm mb-1">Need a server to run {name}?</p>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Deploy {name} on a reliable cloud VPS with GPU support — DigitalOcean and Vultr offer simple pricing, global data centers, and per-second billing for AI workloads.</p>
              <a href="/best-vps-for-ai-deployments-2026" class="inline-flex items-center gap-1.5 text-sm font-medium text-[#0D9488] hover:text-[#0F766E] transition-colors">
                Best VPS for AI Deployments 2026 →
              </a>
            </div>
          </div>
        </div>
        )}
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        
        {affiliate_url && (
          <div class="card p-4 sm:p-5">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-3">{ctaText(pricing)}</h3>
            <a href={affiliate_url} target="_blank" rel="noopener noreferrer" class="btn-primary w-full text-center mb-2">
              {ctaText(pricing)} →
            </a>
            <p class="text-xs text-gray-500 text-center">{pricing}</p>
          </div>
        )}

        <!-- Pricing Tiers -->
        {pricing_tiers && pricing_tiers.length > 0 && (
          <div class="card p-4 sm:p-5">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-3">Pricing</h3>
            <div class="space-y-3">
              {pricing_tiers.map(tier => (
                <div class="p-3 rounded-lg bg-gray-50 dark:bg-gray-800">
                  <div class="flex items-center justify-between">
                    <span class="font-medium text-sm text-gray-900 dark:text-white">{tier.name}</span>
                    <span class="text-[#3B82F6] font-bold">{tier.price}</span>
                  </div>
                  <ul class="mt-2 space-y-1">
                    {tier.features.map(f => (
                      <li class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
                        <span>•</span> {f}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Alternatives in sidebar -->
        {alternatives.length > 0 && (
          <div class="card p-4 sm:p-5">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-3">Alternatives</h3>
            <div class="space-y-2">
              {alternatives.slice(0, 4).map(alt => (
                <a href={`/tool/${alt.data.slug}`} class="block text-sm text-[#3B82F6] hover:underline truncate">
                  {alt.data.name} →
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- We Tested It -->
        <div class="card p-4 sm:p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">We Tested It</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Our reviews are based on hands-on testing and research. We provide honest assessments to help you make informed decisions.
          </p>
        </div>

        <!-- Compare CTA -->
        <div class="card p-4 sm:p-5 bg-gradient-to-br from-[#3B82F6]/5 to-[#8B5CF6]/5 dark:from-[#3B82F6]/10 dark:to-[#8B5CF6]/10">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Compare {name}</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">See how {name} stacks up against similar tools.</p>
          <a href="/compare" class="btn-outline text-xs w-full text-center">Compare Tools →</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
