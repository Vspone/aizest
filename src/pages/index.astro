---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SearchBar from '../components/SearchBar.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ToolCard from '../components/ToolCard.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
const featuredTools = tools.filter(t => t.data.featured).slice(0, 6);

// "Just Added" - newest tools (by pubDate or just last ones added)
const justAdded = tools.slice(-4).reverse();

const categories = [
  { name: 'Writing & Content', icon: '✍️', slug: 'writing', color: 'bg-blue-100 text-blue-600' },
  { name: 'Image Generation', icon: '🎨', slug: 'image', color: 'bg-purple-100 text-purple-600' },
  { name: 'Video Creation', icon: '🎬', slug: 'video', color: 'bg-pink-100 text-pink-600' },
  { name: 'Audio & Voice', icon: '🎵', slug: 'audio', color: 'bg-green-100 text-green-600' },
  { name: 'Coding & Dev', icon: '💻', slug: 'coding', color: 'bg-cyan-100 text-cyan-600' },
  { name: 'Marketing & SEO', icon: '📈', slug: 'marketing', color: 'bg-orange-100 text-orange-600' },
  { name: 'Productivity', icon: '⚡', slug: 'productivity', color: 'bg-amber-100 text-amber-600' },
  { name: 'Data & Analytics', icon: '📊', slug: 'data', color: 'bg-indigo-100 text-indigo-600' },
  { name: 'Design & Creative', icon: '🎯', slug: 'design', color: 'bg-rose-100 text-rose-600' },
  { name: 'Business & Finance', icon: '💼', slug: 'business', color: 'bg-teal-100 text-teal-600' },
];

const toolCounts: Record<string, number> = {};
for (const t of tools) {
  toolCounts[t.data.category] = (toolCounts[t.data.category] || 0) + 1;
}
---

<BaseLayout title="AI Zest — Discover the Best AI Tools">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <Hero />
    
    <div class="mt-4 mb-16">
      <SearchBar />
    </div>

    <!-- Categories -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
          Browse by Category
        </h2>
        <span class="text-sm text-gray-500 dark:text-gray-400">
          {tools.length} tools across {categories.length} categories
        </span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.map(cat => (
          <CategoryCard 
            name={cat.name}
            icon={cat.icon}
            slug={cat.slug}
            count={toolCounts[cat.slug] || 0}
            color={cat.color}
          />
        ))}
      </div>
    </section>

    <!-- Just Added -->
    {justAdded.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-2 mb-6">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
            Just Added
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {justAdded.map(tool => (
            <ToolCard tool={tool} />
          ))}
        </div>
      </section>
    )}

    <!-- Featured Tools -->
    {featuredTools.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
            ★ Featured Picks
          </h2>
          <a href="/category/writing" class="text-sm text-[#3B82F6] hover:underline font-medium">
            View All Tools →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTools.map(tool => (
            <ToolCard tool={tool} />
          ))}
        </div>
      </section>
    )}

    <!-- Articles & Reviews -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
          📝 Articles & Reviews
        </h2>
        <span class="text-sm text-gray-500 dark:text-gray-400">
          In-depth comparisons & guides
        </span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/best-ai-marketing-tools-2026" class="group block p-5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 transition-all duration-200">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-lg">📈</span>
            <span class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors">Best AI Marketing Tools 2026</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400">Semrush, Jasper, Surfer SEO, Writesonic, Copy.ai & HubSpot compared</p>
          <span class="text-xs text-[#3B82F6] mt-2 inline-block group-hover:translate-x-0.5 transition-transform">Read →</span>
        </a>
        <a href="/midjourney-vs-dalle-vs-stable-diffusion" class="group block p-5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 transition-all duration-200">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-lg">🎨</span>
            <span class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors">Midjourney vs DALL-E 3 vs SD</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400">Which AI image generator comes out on top in 2026?</p>
          <span class="text-xs text-[#3B82F6] mt-2 inline-block group-hover:translate-x-0.5 transition-transform">Read →</span>
        </a>
        <a href="/jasper-vs-writesonic-vs-copyai" class="group block p-5 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-[#3B82F6]/40 dark:hover:border-[#3B82F6]/40 transition-all duration-200">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-lg">✍️</span>
            <span class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#3B82F6] transition-colors">Jasper vs Writesonic vs Copy.ai</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400">The ultimate AI writing tool showdown for 2026</p>
          <span class="text-xs text-[#3B82F6] mt-2 inline-block group-hover:translate-x-0.5 transition-transform">Read →</span>
        </a>
      </div>
    </section>

    <!-- Stats + Newsletter combo -->
    <section class="mb-16">
      <div class="rounded-2xl border border-gray-200 dark:border-gray-800 overflow-hidden">
        <div class="py-10 px-8 bg-gradient-to-br from-[#3B82F6]/5 to-[#8B5CF6]/5 dark:from-[#3B82F6]/10 dark:to-[#8B5CF6]/10">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8 text-center mb-6 sm:mb-10">
            <div>
              <div class="text-2xl sm:text-3xl font-bold text-[#3B82F6]">{tools.length}+</div>
              <div class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 mt-1">AI Tools Reviewed</div>
            </div>
            <div>
              <div class="text-2xl sm:text-3xl font-bold text-[#8B5CF6]">{categories.length}</div>
              <div class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 mt-1">Categories</div>
            </div>
            <div>
              <div class="text-2xl sm:text-3xl font-bold text-[#3B82F6]">2026</div>
              <div class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 mt-1">Continuously Updated</div>
            </div>
          </div>

          <div class="max-w-lg mx-auto text-center">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Stay Updated</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Get new AI tools and reviews delivered to your inbox.</p>
            <div class="ml-embedded" data-form="J0miZX"></div>
          </div>

        </div>
      </div>
    </section>

  </div>
</BaseLayout>
