---
import { Icon } from 'astro-icon/components';
---

<header class="sticky top-0 z-50 border-b border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-950/90 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl font-bold bg-gradient-to-r from-[#3B82F6] to-[#8B5CF6] bg-clip-text text-transparent">
          AI Zest
        </span>
      </a>
      
      <nav class="hidden md:flex items-center gap-6">
        <a href="/" class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          Home
        </a>
        <a href="/category/writing" class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          Categories
        </a>
        <a href="/best/best-ai-writing-tools-2026" class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          Best Of
        </a>
        <a href="/about" class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          About
        </a>
      </nav>
      
      <a href="/category/writing" class="btn-primary text-sm">
        Browse Tools
      </a>
    </div>
  </div>
</header>
