const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best AI SEO Tools 2026",
  "description": description,
  "datePublished": "2026-06-23",
  "dateModified": "2026-06-27",
  "author": {
    "@type": "Organization",
    "name": "AI Zest"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AI Zest"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://aizest.net${canonical}`
  }
});

// FAQ JSON-LD for rich snippets
const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
