---
// ListenButton — text-to-speech via Web Speech API
// Place inside an article page; it reads the nearest <article> content
export interface Props {
  articleSelector?: string;
}
const { articleSelector = 'article' } = Astro.props;
---

<div id="listen-wrapper" class="mb-8">
  <button id="listen-btn" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 hover:border-[#3B82F6]/40 transition-all duration-200 tap-feedback">
    <svg id="listen-icon-play" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <svg id="listen-icon-pause" class="hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span id="listen-label">Listen to this article</span>
    <span id="listen-ptotal" class="text-xs text-gray-400 hidden"></span>
  </button>
</div>

<script>
(function() {
  'use strict';
  var btn = document.getElementById('listen-btn');
  var label = document.getElementById('listen-label');
  var playIcon = document.getElementById('listen-icon-play');
  var pauseIcon = document.getElementById('listen-icon-pause');
  if (!btn || !label) return;

  var article = document.querySelector('article');
  if (!article) { btn.style.display = 'none'; return; }

  var paragraphs = [];
  var currentIdx = 0;
  var isPlaying = false;
  var isPaused = false;
  var isStopping = false;
  var currentVoices = [];

  // Extract text preserving paragraph breaks
  function extractParagraphs() {
    var clone = article.cloneNode(true);
    // Remove elements that shouldn't be read
    clone.querySelectorAll('script, style, nav, .btn-primary, [id^="listen-"], pre, code, [class*="btn-"]').forEach(function(el) { el.remove(); });

    var html = clone.innerHTML;
    // Replace closing block tags with double newlines (paragraph markers)
    html = html.replace(/<\/(p|h[1-6]|li|blockquote|div|section)>/gi, '\n\n');
    // Remove remaining HTML tags
    html = html.replace(/<[^>]+>/g, '');
    // Decode common entities
    html = html.replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&nbsp;/g, ' ');
    // Normalize whitespace
    html = html.replace(/\n{3,}/g, '\n\n');
    // Split into paragraphs
    var raw = html.split('\n\n').map(function(s) { return s.trim(); }).filter(Boolean);
    // Merge very short fragments into previous paragraph
    var merged = [];
    for (var i = 0; i < raw.length; i++) {
      if (raw[i].length < 30 && merged.length > 0) {
        merged[merged.length - 1] += ' ' + raw[i];
      } else {
        merged.push(raw[i]);
      }
    }
    // Limit total text
    var total = merged.join(' ').length;
    if (total > 8000) {
      var keep = [];
      var len = 0;
      for (var i = 0; i < merged.length; i++) {
        if (len + merged[i].length > 8000) break;
        keep.push(merged[i]);
        len += merged[i].length;
      }
      merged = keep;
    }
    return merged;
  }

  function stop() {
    isStopping = true;
    isPlaying = false;
    isPaused = false;
    currentIdx = 0;
    if (window.speechSynthesis.speaking) {
      window.speechSynthesis.cancel();
    }
    label.textContent = 'Listen to this article';
    playIcon.classList.remove('hidden');
    pauseIcon.classList.add('hidden');
    btn.classList.remove('ring-2', 'ring-[#3B82F6]/50');
  }

  function speakParagraph(index) {
    if (isStopping || index >= paragraphs.length) {
      if (index >= paragraphs.length) {
        // Finished all paragraphs
        isPlaying = false;
        label.textContent = 'Listen again';
        playIcon.classList.remove('hidden');
        pauseIcon.classList.add('hidden');
        btn.classList.remove('ring-2', 'ring-[#3B82F6]/50');
      }
      return;
    }

    currentIdx = index;
    var text = paragraphs[index];

    var utter = new SpeechSynthesisUtterance(text);
    utter.rate = 0.85;
    utter.pitch = 1.0;

    // Pick best English voice
    var pref = currentVoices.find(function(v) { return v.lang.startsWith('en') && (v.name.includes('Natural') || v.name.includes('Google UK') || v.name.includes('Microsoft')); })
            || currentVoices.find(function(v) { return v.lang.startsWith('en'); });
    if (pref) utter.voice = pref;

    utter.onstart = function() {
      if (!isPlaying) {
        isPlaying = true;
        label.textContent = 'Playing…' + (paragraphs.length > 1 ? ' (' + (index + 1) + '/' + paragraphs.length + ')' : '');
        playIcon.classList.add('hidden');
        pauseIcon.classList.remove('hidden');
        btn.classList.add('ring-2', 'ring-[#3B82F6]/50');
      }
    };

    utter.onend = function() {
      if (isStopping) return;
      // 350ms pause between paragraphs for natural breathing
      setTimeout(function() {
        speakParagraph(index + 1);
      }, 350);
    };

    utter.onerror = function(e) {
      if (e.error === 'canceled' || e.error === 'interrupted') return;
      // Skip this paragraph and continue
      setTimeout(function() {
        speakParagraph(index + 1);
      }, 200);
    };

    window.speechSynthesis.speak(utter);
  }

  function start() {
    isStopping = false;
    currentIdx = 0;
    paragraphs = extractParagraphs();
    if (paragraphs.length === 0) { label.textContent = 'Nothing to read'; return; }
    speakParagraph(0);
  }

  btn.addEventListener('click', function() {
    if (isPlaying && !isPaused) {
      // Pause
      window.speechSynthesis.pause();
      isPaused = true;
      label.textContent = 'Paused';
      playIcon.classList.remove('hidden');
      pauseIcon.classList.add('hidden');
    } else if (isPaused) {
      // Resume
      window.speechSynthesis.resume();
      isPaused = false;
      label.textContent = 'Playing…' + (paragraphs.length > 1 ? ' (' + (currentIdx + 1) + '/' + paragraphs.length + ')' : '');
      playIcon.classList.add('hidden');
      pauseIcon.classList.remove('hidden');
    } else {
      // Start fresh
      stop();
      start();
    }
  });

  // Stop on page unload
  window.addEventListener('beforeunload', function() { window.speechSynthesis.cancel(); });

  // Load voices (async on some browsers)
  currentVoices = window.speechSynthesis.getVoices();
  if (currentVoices.length === 0) {
    window.speechSynthesis.addEventListener('voiceschanged', function() {
      currentVoices = window.speechSynthesis.getVoices();
    }, { once: true });
  }
})();
</script>
