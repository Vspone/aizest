---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleWrap from '../components/ArticleWrap.astro';

// Article JSON-LD
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
