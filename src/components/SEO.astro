---
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  jsonLd?: string;
}

const { 
  title = 'AI Zest — Honest AI Tool Reviews & Comparisons',
  description = 'Side-by-side comparisons, feature breakdowns, and curated guides to help you find the right AI tool for any task.',
  canonical,
  ogImage = '/images/og-default.png',
  type = 'website',
  jsonLd,
} = Astro.props;

const siteUrl = 'https://aizest.net';

// Normalize canonical URL to include trailing slash (Cloudflare redirects non-slash → slash)
// Root '/' already has slash; skip for full absolute URLs
function addTrailingSlash(url: string): string {
  if (url === '/' || url.endsWith('/')) return url;
  const parsed = new URL(url, siteUrl);
  const path = parsed.pathname;
  if (!path.endsWith('/') && !path.includes('.')) return `${url}/`;
  return url;
}

// Support both relative (e.g., '/tool/chatgpt') and absolute (e.g., 'https://aizest.net/best-ai')
// canonical props. Prepend siteUrl only if relative; absolutize if needed first.
function resolveCanonical(input: string | undefined, fallbackUrl: URL): string {
  if (!input) return addTrailingSlash(fallbackUrl.href);
  // If already absolute, use as-is
  if (input.startsWith('http://') || input.startsWith('https://')) return addTrailingSlash(input);
  // Relative path: prepend siteUrl
  return addTrailingSlash(`${siteUrl}${input}`);
}

const fullUrl = resolveCanonical(canonical, Astro.url);
const fullImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// WebSite Schema (homepage only)
const websiteJsonLd = !canonical || canonical === '/' ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "AI Zest",
  "url": siteUrl,
  "description": description,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${siteUrl}/?s={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
}) : null;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href={fullUrl} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={fullUrl} />
<meta property="og:type" content={type} />
<meta property="og:image" content={fullImage} />
<meta property="og:site_name" content="AI Zest" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImage} />

<!-- Search Console / Bing Webmaster — verified via DNS -->

<!-- Structured Data -->
{jsonLd && (
  <script type="application/ld+json" set:html={jsonLd} />
)}

<!-- WebSite Schema (homepage only) -->
{websiteJsonLd && (
  <script type="application/ld+json" set:html={websiteJsonLd} />
)}
