// Breadcrumb JSON-LD
const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aizest.net/" },
    { "@type": "ListItem", "position": 2, "name": "HeyGen vs Synthesia 2026: Which AI Avatar Platform Is Better?" }
  ]
});

const title = "HeyGen vs Synthesia 2026: Best AI Avatar Platform? — AI Zest";
const description = "We tested HeyGen and Synthesia head-to-head on avatar naturalness, voice cloning, language support, ease of use, enterprise features, and pricing. Find the best AI avatar platform in 2026.";
